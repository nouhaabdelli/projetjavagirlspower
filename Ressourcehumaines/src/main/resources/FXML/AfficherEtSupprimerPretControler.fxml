<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gui.AfficherEtSupprimerPretControler"
            prefHeight="400.0" prefWidth="600.0">
    <children>
        <VBox spacing="10" padding="20">
            <Label text="VOS DEMANDES DE PRÊT" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

            <Button fx:id="btnAfficher" text="Afficher" onAction="#afficher" maxWidth="100" />

            <TableView fx:id="tablepret" prefHeight="200">
                <columns>
                    <TableColumn text="ID" fx:id="colId" />
                    <TableColumn text="Montant" fx:id="colMontant" />
                    <TableColumn text="Durée" fx:id="colDuree" />
                    <TableColumn text="Date" fx:id="colDate" />
                    <TableColumn text="Urgence" fx:id="colUrgence" />
                    <TableColumn text="Motif" fx:id="colMotif" />
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="ID à supprimer :" />
                <TextField fx:id="idasupprimer" />
                <Button fx:id="btnSupprimer" text="Supprimer" onAction="#supprimer" />
            </HBox>
        </VBox>
    </children>

</AnchorPane>
